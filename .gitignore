# ============================================
# Project Specific
# ============================================

# Logs directory (created at runtime)
logs/
*.log

# Output files (benchmarks, recordings)
outputs/
*.csv

# Third party dependencies (cloned at setup)
third_party/

# Model cache (downloaded from HuggingFace)
models_cache/
.cache/

# MuJoCo rendering artifacts
*.png
*.jpg
*.jpeg
*.mp4
*.avi

# ============================================
