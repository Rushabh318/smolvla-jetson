# ============================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ============================================
# IDE
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ============================================
