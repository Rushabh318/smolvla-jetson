<mujoco model="so_arm100_pick">
  <include file="so_arm100_with_cam.xml"/>

  <!-- Free camera default: 3/4 view from robot's left-front -->
  <statistic center="0 -0.15 0.15" extent="0.55"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-20" offwidth="512" offheight="512"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.2 0.2" rgb2="0.15 0.15 0.15"
      markrgb="0.5 0.5 0.5" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="6 6" reflectance="0.05"/>
    <material name="table" rgba="0.22 0.22 0.22 1"/>
    <material name="cube" rgba="1 0.2 0.1 1"/>
  </asset>

  <worldbody>
    <!-- Ambient + directional lighting -->
    <light pos="0 -0.1 1.2" dir="0 0.05 -1" directional="true" diffuse="0.7 0.7 0.7"/>
    <light pos="0.4 0.3 0.8" dir="-0.4 -0.5 -0.8" diffuse="0.3 0.3 0.3" specular="0.05 0.05 0.05"/>

    <!-- Floor (dark, contrasts with table surface) -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table surface: robot base sits at origin (z=0), table surface is the same plane.
         Covers the workspace in front of the robot (-y direction) and under it.
         Thin slab sitting at z=0 so top face is flush with robot base. -->
    <geom name="table_surface" type="box" size="0.30 0.28 0.005"
          pos="0.0 -0.12 -0.005" material="table"/>

    <!-- Red cube: 3cm side, sitting on table surface (z=0 + half-height=0.015) -->
    <body name="cube" pos="0.0 -0.20 0.015">
      <freejoint name="cube_joint"/>
      <geom name="cube_geom" type="box" size="0.015 0.015 0.015"
            material="cube" mass="0.05"
            solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001"/>
    </body>

    <!-- Top camera: raised to z=0.85 for wider bird's-eye view.
         pos=(0, -0.05, 0.85), target=(0, -0.15, 0) → look dir (0,-0.116,-0.993).
         Z_cam=(0,0.116,0.993), Y_cam=Z×X=(0,0.993,-0.116) → xyaxes="1 0 0 0 0.993 -0.116" -->
    <camera name="top" pos="0.0 -0.05 0.85" xyaxes="1 0 0 0 0.993 -0.116"/>
  </worldbody>
</mujoco>
