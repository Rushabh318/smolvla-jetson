<mujoco model="so_arm100_pick">
  <include file="so_arm100_with_cam.xml"/>

  <statistic center="0.1 0.15 0.2" extent="0.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="512" offheight="512"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.25 0.25 0.25" rgb2="0.2 0.2 0.2"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="4 4" reflectance="0.1"/>
    <material name="table" rgba="0.85 0.75 0.6 1"/>
    <material name="cube" rgba="1 0.2 0.1 1"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <light pos="0.3 -0.3 0.8" dir="-0.3 0.3 -0.8" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>

    <!-- Floor -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table: surface at z=0.3, robot base at origin -->
    <geom name="table_top" type="box" size="0.25 0.2 0.015"
          pos="0.0 0.22 0.285" material="table"/>
    <geom name="table_leg1" type="box" size="0.015 0.015 0.135" pos=" 0.22  0.38 0.135" material="table"/>
    <geom name="table_leg2" type="box" size="0.015 0.015 0.135" pos="-0.22  0.38 0.135" material="table"/>
    <geom name="table_leg3" type="box" size="0.015 0.015 0.135" pos=" 0.22  0.06 0.135" material="table"/>
    <geom name="table_leg4" type="box" size="0.015 0.015 0.135" pos="-0.22  0.06 0.135" material="table"/>

    <!-- Red cube: 5cm side, resting on table surface -->
    <body name="cube" pos="0.0 0.2 0.325">
      <freejoint name="cube_joint"/>
      <geom name="cube_geom" type="box" size="0.025 0.025 0.025"
            material="cube" mass="0.05"
            solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001"/>
    </body>

    <!-- Top camera: above workspace, looking down toward table (y=0.22, z=0.3) -->
    <!-- xyaxes computed so camera looks along direction (0, 0.51, -0.86) -->
    <camera name="top_cam" pos="0.0 -0.1 0.8" xyaxes="1 0 0 0 0.857 0.514"/>
  </worldbody>
</mujoco>
